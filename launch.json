{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/.vscode/build/zephyr/zephyr.elf",
            "armToolchainPath": "/path/to/arm-zephyr-eabi/bin",
            "toolchainPrefix": "arm-zephyr-eabi",
            "gdbPath": "/path/to/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb",
            "servertype": "jlink",
            "device": "STM32H743XI?BankAddr=0x90000000&Loader=CLK@PF10_nCS@PG6_D0@PF8_D1@PF9_D2@PF7_D3@PF6",
            "interface": "swd",
            "svdFile": "${workspaceFolder}/.vscode/svd/stm32h743.svd",
            "runToEntryPoint": "main"
        },
        {
            "name": "Attach",
            "type": "cortex-debug",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/.vscode/build/zephyr/zephyr.elf",
            "armToolchainPath": "/path/to/arm-zephyr-eabi/bin",
            "toolchainPrefix": "arm-zephyr-eabi",
            "gdbPath": "/path/to/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb",
            "servertype": "jlink",
            "device": "STM32H743XI?BankAddr=0x90000000&Loader=CLK@PF10_nCS@PG6_D0@PF8_D1@PF9_D2@PF7_D3@PF6",
            "interface": "swd",
            "svdFile": "${workspaceFolder}/.vscode/svd/stm32h743.svd"
        }
    ]
}
