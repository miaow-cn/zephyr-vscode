{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/.vscode/build/zephyr/zephyr.elf",
            "armToolchainPath": "/path/to/arm-zephyr-eabi/bin",
            "toolchainPrefix": "arm-zephyr-eabi",
            "gdbPath": "/path/to/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb",
            "servertype": "jlink",
            "device": "RW612",
            "interface": "swd",
            "svdFile": "${workspaceFolder}/.vscode/svd/rw612.svd",
            "runToEntryPoint": "main"
        },
        {
            "name": "Attach",
            "type": "cortex-debug",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/.vscode/build/zephyr/zephyr.elf",
            "armToolchainPath": "/path/to/arm-zephyr-eabi/bin",
            "toolchainPrefix": "arm-zephyr-eabi",
            "gdbPath": "/path/to/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb",
            "servertype": "jlink",
            "device": "RW612",
            "interface": "swd",
            "svdFile": "${workspaceFolder}/.vscode/svd/rw612.svd"
        }
    ]
}
